# 10xProductivity — environment variables
# Copy relevant lines to your .env at the repo root and fill in real values.
# Never commit .env to git.

# --- Jira ---
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_BASE_URL=https://yourcompany.atlassian.net
# Auth is Basic base64(email:token) — not Bearer. Always load via Python, not bash source.
# Generate token at: Jira → Profile photo → Manage account → Security → API tokens → Create

# --- GitHub ---
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_BASE_URL=https://api.github.com
# For GitHub Enterprise: GITHUB_BASE_URL=https://your-ghe.example.com/api/v3
# Generate token at: GitHub → Settings → Developer settings → Personal access tokens

# --- Confluence ---
CONFLUENCE_TOKEN=your-confluence-api-token
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki
# For Confluence Server: CONFLUENCE_BASE_URL=https://confluence.yourcompany.com
# Generate token at: Confluence → Profile → Personal Access Tokens

# --- Grafana ---
# Short-lived (~8h) — refresh with: python3 tool_connections/assets/playwright_sso.py
GRAFANA_BASE_URL=https://grafana.yourcompany.com
GRAFANA_SESSION=your-grafana-session-cookie-value

# --- Slack ---
# Short-lived (~8h) — refresh with: python3 tool_connections/assets/playwright_sso.py --slack-only
SLACK_WORKSPACE_URL=https://yourcompany.slack.com/
SLACK_XOXC=xoxc-your-slack-client-token
SLACK_D_COOKIE=xoxd-your-slack-d-cookie-value

# --- PagerDuty ---
PAGERDUTY_TOKEN=your-pagerduty-personal-api-key
# Generate at: PagerDuty → My Profile → User Settings → API Access → Create New API Key

# --- Microsoft Teams (personal) (teams.live.com) ---
# Short-lived (~24h) — refresh with: python3 tool_connections/assets/playwright_sso.py --teams-only
TEAMS_SKYPETOKEN=your-skypetoken-here
TEAMS_SESSION_ID=your-session-id-uuid-here
TEAMS_BASE_URL=https://teams.live.com

# --- Google Drive ---
# Long-lived (days/weeks) — refresh with: python3 tool_connections/assets/playwright_sso.py --gdrive-only
# Primary auth is via ~/.browser_automation/gdrive_auth.json (Playwright storage_state)
# These .env vars are informational only — the storage_state file is what the skill uses
GDRIVE_COOKIES=SID=...; HSID=...; SAPISID=...
GDRIVE_SAPISID=your-sapisid-value-only

# --- Outlook / Microsoft 365 (work account) ---
# Short-lived (~1h) — refresh with: python3 tool_connections/assets/playwright_sso.py --outlook-only
# Browser opens → Azure AD SSO auto-completes on managed machines (Intune/MDM), ~30s
# graph.microsoft.com token — user profile, people suggestions
GRAPH_ACCESS_TOKEN=your-graph-bearer-token-here
# outlook.office.com/api/v2.0 token — mail, calendar, contacts
OWA_ACCESS_TOKEN=your-owa-bearer-token-here
